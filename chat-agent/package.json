{
  "name": "worker-ai",
  "type": "module",
  "scripts": {
    "dev": "bun --hot ./src/index.ts",
    "test": "bun test",
    "debug": "bun --inspect=localhost:4000/prefix ./src/index.ts",
    "build:standalone": "bun build --compile --minify --sourcemap ./src/index.ts --outfile=myapp",
    "build": "bun build --minify ./src/index.ts --outdir ./dist --target bun",
    "start": "bun ./dist/index.js"
  },
  "dependencies": {
    "@sentry/bun": "^10.32.1",
    "hono": "^4.10.8",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "module": "src/index.ts",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
