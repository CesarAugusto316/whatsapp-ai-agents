{
  "name": "worker-ai",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot ./src/index.ts",
    "debug": "bun run --inspect=localhost:4000/prefix ./src/index.ts",
    "build:standalone": "bun build --compile --minify --sourcemap ./src/index.ts --outfile=myapp",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun run ./dist/index.js",
    "db:tunnel": "cloudflared access tcp --hostname pg-tunnel.osit4s.com --url localhost:15432"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.28",
    "ai": "^5.0.108",
    "hono": "^4.10.8",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "module": "src/index.ts",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
