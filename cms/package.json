{
  "name": "payload-templae",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun --bun  next dev -p 3001",
    "debug": "NODE_OPTIONS=--inspect bun --bun  next dev -p 3001 ",
    "docker:run": "docker run --env-file .env -p 3000:3000 cms:latest",
    "docker:build": "docker build -t cms:latest .",
    "build": "NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" bun --bun  next build",
    "start": "bun --bun  next start",
    "devsafe": "bun --bun rm -rf .next && rm -rf .open-next &&  next dev",
    "db:tunnel": "cloudflared access tcp --hostname pg-tunnel.osit4s.com --url localhost:15432",
    "db:schema": "bun payload generate:db-schema",
    "db:migrate": "bun payload migrate",
    "db:migrate:create": "bun payload migrate:create",
    "db:status": "bun payload migrate:status",
    "db:seed": "bun run db:fresh --force-accept-warning && bun payload seed && bun run generate:importmap && bun run generate:types:payload",
    "db:down": "payload migrate:down",
    "db:fresh": "payload migrate:fresh",
    "db:reset": "payload migrate:reset",
    "generate:importmap": "payload generate:importmap",
    "generate:types:payload": "payload generate:types",
    "payload": "IS_CLI=true payload",
    "ii": "bun install --ignore-workspace",
    "lint": "bun --bun  next lint",
    "test": "bun run test",
    "test:e2e": "--no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.63.0",
    "@payloadcms/email-resend": "3.63.0",
    "@payloadcms/next": "3.63.0",
    "@payloadcms/storage-s3": "3.63.0",
    "@payloadcms/translations": "^3.63.0",
    "@payloadcms/ui": "3.63.0",
    "@visx/axis": "^3.12.0",
    "@visx/event": "^3.12.0",
    "@visx/glyph": "^3.12.0",
    "@visx/legend": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "@visx/vendor": "^3.12.0",
    "date-fns-tz": "^3.2.0",
    "leaflet": "^1.9.4",
    "next": "15.4.7",
    "payload": "3.63.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@testing-library/react": "16.3.0",
    "@types/bun": "^1.3.5",
    "@types/leaflet": "^1.9.21",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.7",
    "jsdom": "26.1.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10",
    "bun": "^1.0.0"
  },
  "bun": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
